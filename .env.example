# Copy to .env and edit for your environment. .env is gitignored.

# --- Django core ---
# Generate with: uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
# Comma-separated list, e.g. "example.org,www.example.org"
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# SQLite (default). For Postgres: postgres://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# --- Media / uploads ---
# Absolute path where stimulus audio files are stored. Defaults to ./media.
# MEDIA_ROOT=/var/lib/webeval/media
# Max per-file upload size in bytes (default ~10 MB).
# STIMULUS_MAX_UPLOAD_BYTES=10485760

# --- GeoIP (optional) ---
# Absolute path to a MaxMind GeoLite2-Country.mmdb file. If unset or missing,
# participant country_code is stored as NULL — the app does not fail.
# GEOIP_PATH=/var/lib/webeval/GeoLite2-Country.mmdb
